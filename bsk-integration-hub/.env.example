# ─────────────────────────────────────────────────────────────────────────────
# BSK Integration Hub — пример конфигурации.
# Скопируйте в `.env` и заполните. НИКОГДА не коммитьте реальный `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# --- Приложение ---
APP_ENV=dev                       # dev | prod
APP_NAME=bsk-integration-hub
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false                    # true для структурированных логов в проде

# --- БЕЗОПАСНОСТЬ ВЫЗОВОВ (три независимых предохранителя) ---
# Все реальные вызовы к Bitrix24/МойСклад заблокированы, пока НЕ выполнены ВСЕ три:
#   ALLOW_REAL_API=true  И  USE_MOCK_CONNECTORS=false  И  DRY_RUN=false
DRY_RUN=true                      # true: операции только планируются и логируются
USE_MOCK_CONNECTORS=true          # true: коннекторы возвращают моки, сети нет
ALLOW_REAL_API=false              # главный рубильник исходящих вызовов

# --- Admin API ---
# Токен для доступа к /api/admin/* (Bearer или заголовок X-Admin-Token).
# Обязателен. Сгенерируйте, например: openssl rand -hex 32
ADMIN_API_TOKEN=change-me-please-generate-a-long-random-token
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# --- База данных ---
# Локально по умолчанию SQLite (без внешних зависимостей).
# В docker-compose переопределяется на PostgreSQL.
DATABASE_URL=sqlite:///./data/app.db
# Пример для PostgreSQL:
# DATABASE_URL=postgresql+psycopg://bsk:bsk@localhost:5432/bsk

# --- Очередь (Redis / RQ) ---
QUEUE_BACKEND=sync                # sync | redis  (sync = исполнение в процессе, без воркера)
REDIS_URL=redis://localhost:6379/0
QUEUE_NAME=operations
WORKER_MAX_RETRIES=5
WORKER_BACKOFF_BASE_SECONDS=2
WORKER_BACKOFF_MAX_SECONDS=300
OPERATION_LOCK_TTL_SECONDS=300

# --- Approval gate ---
# Список типов операций (через запятую), требующих ручного подтверждения.
APPROVAL_REQUIRED_FOR=order_delete,invoice_void

# --- Bitrix24 (используются ТОЛЬКО при реальном режиме) ---
BITRIX24_BASE_URL=
BITRIX24_OUTBOUND_WEBHOOK_URL=
BITRIX24_INBOUND_WEBHOOK_SECRET=

# --- МойСклад (используются ТОЛЬКО при реальном режиме) ---
MOYSKLAD_BASE_URL=https://api.moysklad.ru/api/remap/1.2
MOYSKLAD_TOKEN=
MOYSKLAD_INBOUND_WEBHOOK_SECRET=

# --- AI-ассистент (плейсхолдер; пока не подключён) ---
ASSISTANT_ENABLED=false
ASSISTANT_PROVIDER=
ASSISTANT_API_KEY=
