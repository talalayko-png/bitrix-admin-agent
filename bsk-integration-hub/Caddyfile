# Caddy reverse proxy with automatic HTTPS (Let's Encrypt).
# DOMAIN and ACME_EMAIL come from the environment (see .env / docker-compose.prod.yml).

{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode gzip
	# All API + webhook traffic is proxied to the FastAPI app on the internal network.
	reverse_proxy app:8000
}
