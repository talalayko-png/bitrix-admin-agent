# Caddy: serve the admin-panel SPA and reverse-proxy the API to the backend.
# Automatic HTTPS (Let's Encrypt). DOMAIN / ACME_EMAIL come from the environment.

{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode gzip

	# Backend (FastAPI): API, inbound webhooks, health and API docs.
	handle /api/* {
		reverse_proxy app:8000
	}
	handle /webhooks/* {
		reverse_proxy app:8000
	}
	handle /health {
		reverse_proxy app:8000
	}
	handle /docs {
		reverse_proxy app:8000
	}
	handle /openapi.json {
		reverse_proxy app:8000
	}

	# Everything else → admin-panel SPA (client-side routing falls back to index.html).
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
